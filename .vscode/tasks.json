{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run: show-arguments",
      "type": "process",
      "command": "node",
      "args": ["build/show-arguments.js"],
      "dependsOn": ["npm: build:show-arguments"]
    },
    {
      "label": "Run: update",
      "type": "process",
      "command": "node",
      "args": ["build/update.js"],
      "options": {
        "env": {
          "TEST_MODE": "true"
        }
      },
      "dependsOn": ["npm: build:update"]
    }
  ]
}
